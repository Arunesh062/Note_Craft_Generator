{
  "manifest_version": 3,
  "name": "NoteCraft Generator",
  "version": "2.0",
  "description": "Automatically generate Notes from Google Meet / Zoom with React",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "NoteCraft AI"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["content.iife.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "ready.html",
        "assets/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
